# crs-quota-reader · runtime env
# 这些变量必须与 claude-relay-service 的 .env 保持一致(否则 hash 不上 / 取错数据)。

# ── Redis(与 CRS 同 redis,只读访问) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLE_TLS=

# ── 安全凭据 ─────────────────────────────────────────────────────────────────
# CRS 用 sha256(apiKey + ENCRYPTION_KEY) 作为 hash 索引;本服务必须用同一份才能
# 把 user 提交的 API key 反查到 keyId/account。建议直接 cp ~/claude-relay-service/app/.env
# 里这一行过来。
ENCRYPTION_KEY=replace-with-the-same-value-as-CRS

# ── 业务配置 ─────────────────────────────────────────────────────────────────
# 与 CRS 一致的时区偏移,影响 account_usage:hourly:* 的 key 名构造。
TIMEZONE_OFFSET=8

# Express 监听端口
PORT=11408

# 是否打印每个请求的访问日志
ACCESS_LOG=true
